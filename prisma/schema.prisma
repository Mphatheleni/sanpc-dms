generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DOCUMENT_MANAGER
  REVIEWER
  APPROVER
}

enum DocumentStatus {
  REGISTERED
  DRAFT
  PENDING_REVIEW
  IN_REVIEW
  UPDATING
  REVIEW_COMPLETE
  FINAL_DRAFT
  PENDING_APPROVAL
  APPROVED
  EXCO_PENDING
  CONTROLLED
  SUPERSEDED
  CANCELLED
  REJECTED
  CHANGES_REQUESTED
}

enum ReviewStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum ActivityAction {
  CREATED
  VIEWED
  DOWNLOADED
  SUBMITTED
  REVIEW_APPROVED
  REVIEW_REJECTED
  REVIEW_CHANGES_REQUESTED
  APPROVED
  REJECTED
  COMMENT_ADDED
  CONTROLLED
  SUPERSEDED
  CANCELLED
  EXCO_SUBMITTED
  SIGNED_PAGE_UPLOADED
  AMENDED
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  password       String
  role           Role
  departmentRole String?  // LEGAL | INTERNAL_AUDIT | QUALITY | PROCEDURES
  createdAt      DateTime @default(now())

  uploadedDocuments        Document[]                @relation("UploadedBy")
  originatedDocuments      Document[]                @relation("OriginatorOf")
  authorizedDocuments      Document[]                @relation("AuthorizerOf")
  reviews                  DocumentReview[]
  comments                 DocumentComment[]
  versionUploads           DocumentVersion[]         @relation("VersionUploadedBy")
  activities               DocumentActivity[]        @relation("ActivityUser")
  notifications            Notification[]
  mandatoryReviewerConfigs MandatoryReviewerConfig[]
}

/// Maps a document type to specific mandatory reviewers (person-based).
/// When uploading a document of this type, these people are pre-selected as reviewers.
model MandatoryReviewerConfig {
  id           String   @id @default(cuid())
  documentType String   // e.g. "Policy", "Procedure"
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([documentType, userId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  documentId String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Document {
  id               String         @id @default(cuid())
  title            String
  description      String?
  category         String?
  tags             String?
  fileUrl          String
  fileName         String
  fileType         String
  fileSize         Int
  status           DocumentStatus @default(DRAFT)
  version          Int            @default(1)
  sharePointUrl    String?
  sharePointItemId String?
  reviewDeadlineDays Int?

  // SANPC document control fields
  documentNumber    String?
  revision          String?  @default("00")
  originalDate      String?
  authorisedBy      String?
  originator        String?
  purpose           String?
  documentTypeCode  String?
  nextReviewDate    String?

  // Lifecycle fields
  retentionDate     String?   // 40 years from controlled date
  signedPageUrl     String?   // uploaded signed authorisation page
  signedPageName    String?
  excoResolutionUrl  String?   // Board resolution for Policy docs
  excoResolutionName String?
  isExcoRequired    Boolean   @default(false)
  controlledAt      String?   // date first marked CONTROLLED
  amendmentCount    Int       @default(0)

  originatorId  String?
  originatorUser User?  @relation("OriginatorOf", fields: [originatorId], references: [id], onDelete: SetNull)
  authorizerId  String?
  authorizerUser User?  @relation("AuthorizerOf", fields: [authorizerId], references: [id], onDelete: SetNull)

  uploadedById String
  uploadedBy   User   @relation("UploadedBy", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metadata   DocumentMetadata[]
  reviews    DocumentReview[]
  comments   DocumentComment[]
  versions   DocumentVersion[]
  activities DocumentActivity[]
}

model DocumentMetadata {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  key        String
  value      String
}

model DocumentReview {
  id         String       @id @default(cuid())
  documentId String
  document   Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User         @relation(fields: [reviewerId], references: [id])
  order      Int
  isApprover Boolean      @default(false)
  isMandatory Boolean     @default(false)  // Legal, Internal Audit, Quality, Procedures
  mandatoryRole String?                    // e.g. "LEGAL"
  status     ReviewStatus @default(PENDING)
  comments   String?
  reviewedAt DateTime?
  startedAt  DateTime?
  deadline   DateTime?
  reminderSentAt DateTime?                 // day-18 reminder tracking
}

model DocumentComment {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  content    String
  createdAt  DateTime @default(now())
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber Int
  fileUrl       String
  fileName      String
  fileType      String
  fileSize      Int
  uploadedById  String
  uploadedBy    User     @relation("VersionUploadedBy", fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())
}

model DocumentActivity {
  id         String         @id @default(cuid())
  documentId String
  document   Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation("ActivityUser", fields: [userId], references: [id])
  action     ActivityAction
  details    String?
  createdAt  DateTime       @default(now())
}
