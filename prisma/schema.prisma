generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  DOCUMENT_MANAGER
  REVIEWER
  APPROVER
}

enum DocumentStatus {
  DRAFT
  PENDING_REVIEW
  IN_REVIEW
  REVIEW_COMPLETE
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum ReviewStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum ActivityAction {
  CREATED
  VIEWED
  DOWNLOADED
  SUBMITTED
  REVIEW_APPROVED
  REVIEW_REJECTED
  REVIEW_CHANGES_REQUESTED
  APPROVED
  REJECTED
  COMMENT_ADDED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  uploadedDocuments Document[]        @relation("UploadedBy")
  reviews           DocumentReview[]
  comments          DocumentComment[]
  versionUploads    DocumentVersion[] @relation("VersionUploadedBy")
  activities        DocumentActivity[] @relation("ActivityUser")
}

model Document {
  id          String         @id @default(cuid())
  title       String
  description String?
  category    String?
  tags        String?
  fileUrl           String
  fileName          String
  fileType          String
  fileSize          Int
  status            DocumentStatus @default(DRAFT)
  version           Int            @default(1)
  sharePointUrl     String?
  sharePointItemId  String?
  reviewDeadlineDays Int?

  uploadedById String
  uploadedBy   User   @relation("UploadedBy", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metadata   DocumentMetadata[]
  reviews    DocumentReview[]
  comments   DocumentComment[]
  versions   DocumentVersion[]
  activities DocumentActivity[]
}

model DocumentMetadata {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  key        String
  value      String
}

model DocumentReview {
  id         String       @id @default(cuid())
  documentId String
  document   Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User         @relation(fields: [reviewerId], references: [id])
  order      Int
  isApprover Boolean      @default(false)
  status     ReviewStatus @default(PENDING)
  comments   String?
  reviewedAt DateTime?
  startedAt  DateTime?
  deadline   DateTime?
}

model DocumentComment {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  content    String
  createdAt  DateTime @default(now())
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber Int
  fileUrl       String
  fileName      String
  fileType      String
  fileSize      Int
  uploadedById  String
  uploadedBy    User     @relation("VersionUploadedBy", fields: [uploadedById], references: [id])
  createdAt     DateTime @default(now())
}

model DocumentActivity {
  id         String         @id @default(cuid())
  documentId String
  document   Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation("ActivityUser", fields: [userId], references: [id])
  action     ActivityAction
  details    String?
  createdAt  DateTime       @default(now())
}
